+// Patched in via patch-package — adds a Toggle (switch) component to xfw-ui.
+import { Switch as AriaSwitch } from "react-aria-components";
+import { Fragment, jsx, jsxs } from "react/jsx-runtime";
+import { cx } from "./chunk-BRMLZUTI.js";
+
+var TRACK_OFF = "var(--border, #d0d5dd)";
+var TRACK_ON = "var(--brand, #7f56d9)";
+var KNOB_BG = "var(--bg-card, #ffffff)";
+
+var ToggleBase = ({ className, isSelected, isDisabled, size = "md", isFocusVisible = false }) => {
+  const W = size === "sm" ? 36 : 44;
+  const H = size === "sm" ? 20 : 24;
+  const K = size === "sm" ? 16 : 20;
+  const pad = 2;
+  const tx = isSelected ? W - K - pad * 2 : 0;
+  return /* @__PURE__ */ jsx(
+    "div",
+    {
+      className: cx(
+        "relative inline-flex shrink-0 cursor-pointer items-center rounded-full transition-colors",
+        isDisabled && "cursor-not-allowed opacity-50",
+        isFocusVisible && "outline-2 outline-offset-2 outline-focus-ring",
+        className
+      ),
+      style: {
+        width: W,
+        height: H,
+        padding: pad,
+        backgroundColor: isSelected ? TRACK_ON : TRACK_OFF
+      },
+      children: /* @__PURE__ */ jsx(
+        "span",
+        {
+          className: "block rounded-full shadow transition-transform",
+          style: {
+            width: K,
+            height: K,
+            backgroundColor: KNOB_BG,
+            transform: `translateX(${tx}px)`
+          }
+        }
+      )
+    }
+  );
+};
+ToggleBase.displayName = "ToggleBase";
+
+var Toggle = ({ label, hint, size = "md", className, ...ariaSwitchProps }) => {
+  const sizes = {
+    sm: { root: "gap-2", textWrapper: "", label: "text-sm font-medium", hint: "text-sm" },
+    md: { root: "gap-3", textWrapper: "gap-0.5", label: "text-md font-medium", hint: "text-md" }
+  };
+  return /* @__PURE__ */ jsx(
+    AriaSwitch,
+    {
+      ...ariaSwitchProps,
+      className: (state) => cx(
+        "flex items-center",
+        state.isDisabled && "cursor-not-allowed",
+        sizes[size].root,
+        typeof className === "function" ? className(state) : className
+      ),
+      children: ({ isSelected, isDisabled, isFocusVisible }) => /* @__PURE__ */ jsxs(Fragment, { children: [
+        /* @__PURE__ */ jsx(ToggleBase, {
+          size,
+          isSelected,
+          isDisabled,
+          isFocusVisible
+        }),
+        (label || hint) && /* @__PURE__ */ jsxs("div", { className: cx("inline-flex flex-col whitespace-nowrap", sizes[size].textWrapper), children: [
+          label && /* @__PURE__ */ jsx("span", { className: cx("text-secondary select-none", sizes[size].label), children: label }),
+          hint && /* @__PURE__ */ jsx("span", { className: cx("text-tertiary", sizes[size].hint), onClick: (event) => event.stopPropagation(), children: hint })
+        ] })
+      ] })
+    }
+  );
+};
+Toggle.displayName = "Toggle";
+
+export { Toggle, ToggleBase };
